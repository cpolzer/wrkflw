      "firstName": "Bob",
      "lastName": "Reviewer",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "groups": [
        "legal-reviewers"
      ]
    },
    {
      "username": "carol",
